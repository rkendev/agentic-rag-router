# agentic-rag-router — environment variables
#
# Copy to `.env` (which is gitignored) and fill in real values for the tiers
# you want active. Missing keys cause their adapter to raise LLMPermanentError
# at construction time (fail-fast, per SPECIFICATION §5).
#
# `.env` is loaded by pydantic-settings (D4). Keys are wrapped in SecretStr so
# `print(config)` does not leak them.

# --- Primary tier: Anthropic Claude Haiku ---
# Required for the PRIMARY tier. Leave blank to skip Claude entirely.
ANTHROPIC_API_KEY=
# Override to point the PRIMARY tier at a different Claude model.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Secondary tier: OpenAI gpt-4o-mini ---
# Required for the SECONDARY tier. Leave blank to skip OpenAI entirely.
OPENAI_API_KEY=
# Override to point the SECONDARY tier at a different OpenAI model.
OPENAI_MODEL=gpt-4o-mini

# --- Tertiary tier: local Ollama ---
# Always available when docker compose is running ollama.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Web search tool: Tavily (D3) ---
# Required for the `web_search` tool. Get a key at https://app.tavily.com (the
# replay tests use the scrubbed VCR cassette and need no real key).
TAVILY_API_KEY=__set_me__

# --- Shared adapter behaviour ---
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# --- Observability ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Example CLI (examples/hello_llm) ---
# One of: primary, secondary, tertiary, fallback
# `fallback` runs the three-tier FallbackModel composition.
LLM_TIER=fallback

# --- Data layer: Postgres + pgvector (D2) ---
# Used by scripts/init_db.py, scripts/ingest_*.py, and the integration tests.
# Defaults match docker-compose.yml: the pgvector service is published on the
# host loopback only (127.0.0.1:5436), never exposed publicly.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5436
POSTGRES_DB=dev
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# SELECT-only role the D3 SQL tool connects as. Created by scripts/init_db.py.
# A local dev credential, not a production secret — real .env stays gitignored.
ROUTER_RO_USER=router_ro
ROUTER_RO_PASSWORD=router_ro_dev
